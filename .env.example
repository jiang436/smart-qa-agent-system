# =============================================
# Smart QA Agent System - 环境变量配置
# =============================================
# 复制此文件为 .env，填入你的 API Key 即可运行
# =============================================
# LLM 配置 (DeepSeek 示例)
LLM_API_KEY=your-deepseek-api-key-here
# PostgreSQL
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/agent
# Redis
REDIS_URL=redis://localhost:6379/0
# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=knowledge_base
# 限流
GLOBAL_RATE_LIMIT=100
GLOBAL_REFILL_RATE=10
USER_RATE_LIMIT=20
USER_REFILL_RATE=5
DAILY_TOKEN_BUDGET=1000000
# 缓存
CACHE_TTL=1800
CACHE_SIMILARITY_THRESHOLD=0.95
# Agent
MAX_AGENT_STEPS=15
AGENT_TIMEOUT=30
