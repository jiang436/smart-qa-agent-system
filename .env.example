# =============================================
# Smart QA Agent System - 环境变量配置
# =============================================
# 复制此文件为 .env，填入你的 API Key 即可运行
# =============================================
# LLM Provider
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LIGHTWEIGHT_MODEL=gpt-4o-mini
HEAVY_MODEL=gpt-4o

# Database
POSTGRES_DSN=postgresql+asyncpg://user:password@postgres:5432/agent
REDIS_URL=redis://redis:6379/0

# Milvus
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=knowledge_base

# Security
GLOBAL_RATE_LIMIT=100
GLOBAL_REFILL_RATE=10
USER_RATE_LIMIT=20
USER_REFILL_RATE=5
DAILY_TOKEN_BUDGET=1000000

# Cache
CACHE_TTL=1800
CACHE_SIMILARITY_THRESHOLD=0.95

# Agent
MAX_AGENT_STEPS=15
AGENT_TIMEOUT=60
LOOP_SEMANTIC_THRESHOLD=0.92
LOOP_REPEATED_TOOL_THRESHOLD=3

# Retrieval
RETRIEVAL_L1_THRESHOLD=0.75
RETRIEVAL_L2_THRESHOLD=0.6
RETRIEVAL_TOP_K=5
RETRIEVAL_CRAG_MAX_RETRIES=2
RETRIEVAL_CRAG_QUALITY_HIGH=0.5
RETRIEVAL_CRAG_QUALITY_MEDIUM=0.3

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Memory
SHORT_TERM_WINDOW=6
CACHE_LRU_CAPACITY=1000

# Citation
CITATION_VERIFICATION_THRESHOLD=0.6

# Troubleshoot
TROUBLESHOOT_MAX_ROUNDS=5

# Reflection
REFLECTION_MAX_ROUNDS=3

# Embedding (api / local / ollama)
# 生产推荐 api 模式；本地模型可能因 torch 版本问题 crash
EMBEDDING_BACKEND=api
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_FALLBACK_MODEL=
# EMBEDDING_API_KEY=  # api 模式必须

# Server
HOST=0.0.0.0
PORT=8000

# OneNET IoT
ONENET_API_KEY=***
ONENET_PRODUCT_ID=Wy87oxUFbz
ONENET_DEVICE_U1001=X30Pro_Virtual_01
ONENET_DEVICE_U1002=T10_Virtual_01
ONENET_DEVICE_U1003=X20Pro_Virtual_01

# Observability (Pydantic Logfire)
# 留空则跳过 Logfire，不影响现有 loguru/Prometheus 监控

# Docker 部署 SigNoz 后设为: http://signoz:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=smart-qa-agent
