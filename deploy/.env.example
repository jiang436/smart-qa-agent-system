# LLM Provider
LLM_API_KEY=sk-…
LLM_BASE_URL=https://api.openai.com/v1
LIGHTWEIGHT_MODEL=gpt-4o-mini
HEAVY_MODEL=gpt-4o

# Database
POSTGRES_DSN=postgresql+asyncpg://user:password@postgres:5432/agent
REDIS_URL=redis://redis:6379/0

# Milvus
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=knowledge_base

# Security
GLOBAL_RATE_LIMIT=100
USER_RATE_LIMIT=20
DAILY_TOKEN_BUDGET=1000000

# Cache
CACHE_TTL=1800
CACHE_SIMILARITY_THRESHOLD=0.95

# Agent
MAX_AGENT_STEPS=15

# Embedding
EMBEDDING_BACKEND=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# Observability (Pydantic Logfire — 有 token 时走 Logfire 云)

# 部署 SigNoz 后设为: http://signoz:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=smart-qa-agent
